{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build:api && pnpm run start",
    "build": "pnpm run build:dashboard && pnpm run build:api",
    "build:api": "node ./build.mjs",
    "build:dashboard": "pnpm --filter @workspace/dashboard run build",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "axios": "^1.14.0",
    "better-sqlite3": "^12.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^17.3.1",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "http-proxy-middleware": "^3.0.5",
    "node-telegram-bot-api": "^0.67.0",
    "pino": "^9",
    "pino-http": "^10",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
